# Bu dosya .env.example = ŞABLON (gerçek şifreler buraya yazılmaz, Git'e gider).
# Uygulama çalışırken sadece .env dosyasını okur.
# Kurulum: Bu dosyayı kopyalayın → cp .env.example .env → .env içine gerçek değerleri yazın.
# .env Git'e eklenmez (.gitignore'da); .env.example eklenir.

# OpenAI (zorunlu: analiz için). sk- ile başlamalı; başında/sonunda boşluk bırakmayın.
# Kontrol: GET /api-check → openai_ayarli: true. Production'da anahtar yoksa uygulama başlamaz.
OPENAI_API_KEY=sk-...

# Opsiyonel: Birden fazla anahtar (virgülle ayrılmış). Biri bozulunca veya limit dolunca sıradakine geçilir.
# OPENAI_API_KEYS=sk-xxx,sk-yyy,sk-zzz

# JWT (güçlü rastgele bir key kullanın: openssl rand -hex 32)
SECRET_KEY=your-secret-key-change-in-production

# Veritabanı (SQLite varsayılan; production’da postgresql://...)
DATABASE_URL=sqlite:///./norya.db

# Canlı sunucu için: ENVIRONMENT=production (güvenlik başlıkları, SECRET_KEY kontrolü)
# ENVIRONMENT=production

# Production: CORS (virgülle ayrılmış; * = tüm origin), rate limit
# CORS_ORIGINS=https://norya.com,https://www.norya.com
# RATE_LIMIT_PER_MINUTE=30

# Opsiyonel: Rate limit için Redis (çok worker / birden fazla instance için önerilir).
# Tanımlı değilse SlowAPI in-memory kullanır (limit worker başına uygulanır).
# REDIS_URL=redis://localhost:6379/0

# Opsiyonel: Fiyatlar ülkeye göre yerel para biriminde (SAR, TRY, USD vb.) gösterilir.
# Kurlar app/main.py içinde EUR_RATES ile güncellenebilir; tahsilat her zaman EUR.

# ---------- PayTR (ödeme sayfasının açılması için ZORUNLU) ----------
# PayTR panelinden alın: https://www.paytr.com → Üye İşyeri Paneli → Entegrasyon bilgileri
# Aşağıdaki 3 satırı doldurmadan "Ödeme şu an kullanılamıyor" hatası alırsınız.
PAYTR_MERCHANT_ID=
PAYTR_MERCHANT_KEY=
PAYTR_MERCHANT_SALT=
# Bildirim URL: PayTR panelde Bildirim URL olarak bu adresi girin (HTTPS zorunlu)
# PAYTR_NOTIFICATION_URL=https://noryaai.com/paytr/callback
# Başarılı / başarısız dönüş sayfaları (müşteri yönlendirmesi)
# PAYTR_OK_URL=https://noryaai.com/payment/success
# PAYTR_FAIL_URL=https://noryaai.com/payment/failed
# Test modu: 1 = test, 0 = canlı
# PAYTR_TEST_MODE=1
# EUR mağaza hesabı yoksa PayTR'ye TL gönderilir. 1 EUR = bu kur (örn. 35 → 50€ = 1750 TL)
# PAYTR_EUR_TO_TRY_RATE=35
# Opsiyonel: Uygulama base URL ve varsayılan para birimi
# APP_BASE_URL=https://noryaai.com
# CURRENCY_DEFAULT=EUR
# Fiyatlar (euro cent): 1300 = 13€, 5000 = 50€, 9900 = 99€
# PAYTR_AMOUNT_SINGLE=1300
# PAYTR_AMOUNT_MONTHLY=5000
# PAYTR_AMOUNT_YEARLY=9900

# Destek: Ödeme alındı hak gelmedi durumunda manuel hak tanıma (POST /payment/grant)
# ADMIN_SECRET=your-admin-secret

# E-posta (üyelik doğrulama + şifre sıfırlama). Detay: docs/SMTP_KURULUM.md
# Mevcut hesap support@noryaai.com ise SMTP_USER ve SMTP_FROM olarak bu adresi kullanın.
# SMTP yoksa doğrulama/sıfırlama linki oluşturulur ama mail GÖNDERİLMEZ; kullanıcıya "e-posta gönderilemedi" mesajı gösterilir.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=support@noryaai.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=support@noryaai.com
SMTP_FROM_NAME=Norya
SMTP_USE_TLS=1
# E-postadaki doğrulama/şifre sıfırlama linkinin açılacağı adres. Canlı: https://noryaai.com
FRONTEND_URL=http://127.0.0.1:8000

# Google Analytics 4: Ölçüm kimliği (G-XXXXXXXXXX). Boşsa siteye GA script eklenmez.
# GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Ads: Dönüşüm takibi için hesap kimliği (AW-XXXXXXXXX). Boşsa script eklenmez.
# GOOGLE_ADS_CONVERSION_ID=AW-XXXXXXXXX

# WhatsApp iletişim: sağ alt köşede ve iletişim bölümünde buton. Ülke kodu + numara, + ve boşluksuz (örn. 905551234567).
# WHATSAPP_CONTACT=905551234567

# İletişim ve şirket bilgileri (footer, /legal/iletisim, PayTR uyumluluk). Boş bırakılırsa config varsayılanları kullanılır.
# COMPANY_TITLE=NoryaAI
# COMPANY_AUTHORIZED_PERSON=Ufuk Urhan
# COMPANY_TAX_OFFICE=Banaz
# COMPANY_TAX_NUMBER=8940311420
# COMPANY_ADDRESS=31 Ağustos Mahallesi, Tomurcuk Aysaş Mühendislik No:2 İç Kapı No:4, Banaz/Uşak, Türkiye
# COMPANY_PHONE=+90 507 170 35 64
# COMPANY_SUPPORT_EMAIL=support@noryaai.com
# COMPANY_CONTACT_EMAIL=info@noryaai.com
# COMPANY_COUNTRY=Türkiye

# MinIO (S3 uyumlu): PDF raporları burada saklanır, kullanıcı buradan indirir.
# Tümü dolu ve MINIO_USE_FOR_PDF=1 ise backend PDF'i MinIO'ya yükler ve 302 ile presigned URL'e yönlendirir.
# MINIO_ENDPOINT=minio.example.com
# MINIO_ACCESS_KEY=...
# MINIO_SECRET_KEY=...
# MINIO_BUCKET=norya-pdf
# MINIO_SECURE=1
# MINIO_USE_FOR_PDF=0

# PWA push bildirimleri (opsiyonel): VAPID anahtarları. Boşsa bildirim aboneliği alınmaz.
# Üretmek için: npx web-push generate-vapid-keys
# VAPID_PUBLIC_KEY=...
# VAPID_PRIVATE_KEY=...
