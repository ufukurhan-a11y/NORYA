        "solution_1_title": "Hospitals",
        "solution_1_desc": "Standardize pre-analysis across departments, support clinician handoffs, and keep communication clear between care teams and operations.",
        "solution_2_title": "Clinics",
        "solution_2_desc": "Provide concise visit-ready summaries, improve patient communication clarity, and reduce repetitive administrative review steps.",
        "solution_3_title": "Laboratories",
        "solution_3_desc": "Structure high-volume test outputs before specialist review, helping teams prioritize exceptions and report with consistent language.",
        "solution_4_title": "Provider Networks",
        "solution_4_desc": "Align reporting workflows across distributed providers with shared pre-analysis standards and traceable communication outputs.",
        "card_1_title": "Clinical Pre-Analysis",
        "card_1_desc": "Automated screening and data structuring before the practitioner reviews the file, saving critical hours per patient.",
        "card_2_title": "Multilingual Patient Communication",
        "card_2_desc": "Bridge the gap with instantaneous, clinically-aware translations of complex results for non-native speakers.",
        "card_3_title": "Institutional Security",
        "card_3_desc": "On-premise or sovereign cloud deployment options to meet the most stringent data protection mandates.",
        "card_4_title": "Biomarker Trend Tracking",
        "card_4_desc": "Longitudinal comparison of patient biomarkers across multiple reports for clinical follow-up and monitoring.",
        "card_5_title": "Evidence-Based References",
        "card_5_desc": "AI-generated insights linked to peer-reviewed literature and clinical guidelines for clinician review.",
        "card_6_title": "Critical Value Triage",
        "card_6_desc": "Automatic flagging of out-of-range and critical biomarkers for priority clinical attention.",

        "why_title": "Built for modern healthcare teams",
        "why_desc": "NoryaAI isn't just an AI model; it's a workflow accelerator. Clinical environments demand three things above all: Accuracy, Privacy, and Oversight.",
