# Norya Nginx reverse proxy (HTTP; SSL certbot ile eklenir)
# Kullanım: sudo cp deploy/nginx-norya.conf.example /etc/nginx/sites-available/norya
#          sudo ln -s /etc/nginx/sites-available/norya /etc/nginx/sites-enabled/
#          sudo nginx -t && sudo systemctl reload nginx
# SSL:     sudo certbot --nginx -d norya.example.com

server {
    listen 80;
    server_name norya.example.com www.norya.example.com;

    # Tenant paths - path-based multi-tenant routing
    # /hastane/{tenant_slug}/... -> same backend, tenant resolved by middleware
    location /hastane/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;

        # Tenant path forwarding (optional, for logging/debugging)
        proxy_set_header X-Tenant-Path $request_uri;

        # Increase timeouts for analysis requests
        proxy_read_timeout 120s;
        proxy_connect_timeout 60s;
        proxy_send_timeout 60s;
    }

    # Admin panel
    location /admin/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # API routes
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;

        # Increase timeouts for analysis API
        proxy_read_timeout 120s;
    }

    # Enterprise dashboard
    location /enterprise/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }

    # All other paths (B2C landing, pricing, blog, etc.)
    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Real-IP $remote_addr;
    }
}
